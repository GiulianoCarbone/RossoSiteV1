# ── Copiá este archivo a ".env" y completá tu clave ──
# (el archivo .env está en .gitignore: NO se sube al repo público)

# Proveedor de IA: deepseek | gemini | openai | anthropic
LLM_PROVIDER=deepseek

# Tu clave del proveedor elegido.
# DeepSeek: sacala en https://platform.deepseek.com/api_keys
LLM_API_KEY=PEGA_TU_CLAVE_ACA

# (opcional) modelo a usar. Si lo dejás vacío usa un modelo barato por defecto:
#   deepseek  -> deepseek-chat
#   gemini    -> gemini-2.0-flash
#   openai    -> gpt-4o-mini
#   anthropic -> claude-3-5-haiku-latest
LLM_MODEL=

# (opcional) cuántas llamadas en paralelo (por defecto 3)
CONCURRENCY=3

# ── Scraping web (solo para enriquecer-scrape.mjs) ──
# Key gratis en https://app.tavily.com  (busca specs reales por nombre de producto)
TAVILY_API_KEY=PEGA_TU_CLAVE_TAVILY
# basic = 1 crédito/búsqueda (recomendado) · advanced = 2 créditos (más profundo)
TAVILY_DEPTH=basic

# ── Lectura del catálogo (NO tocar salvo que cambie el proyecto) ──
# Es la API key PÚBLICA de solo-lectura, la misma que ya usa catalogo.html.
FIREBASE_PROJECT=backend-panel-vendedores
FIRESTORE_API_KEY=AIzaSyD9p16QACzSifXaTl1TojcuUKDijuE77S0
